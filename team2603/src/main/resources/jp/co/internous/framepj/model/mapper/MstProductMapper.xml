<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="jp.co.internous.framepj.model.mapper.MstProductMapper">

	<select id="findByCategoryAndProductName" resultType="jp.co.internous.framepj.model.domain.MstProduct">
  		SELECT * FROM mst_product
 		WHERE category_id = #{category}
  
  			<if test="keywords != null and keywords.length > 0">
   			AND (
      			<foreach item="keyword" collection="keywords" separator="OR">
        			product_name LIKE CONCAT('%', #{keyword}, '%')
      			</foreach>
    		)
			</if>
	</select>
    
	<select id="findByProductName" resultType="jp.co.internous.framepj.model.domain.MstProduct">	
		SELECT * FROM mst_product
    	WHERE
   			<foreach item="keyword" collection="keywords" separator="OR">
    			product_name LIKE CONCAT('%', #{keyword}, '%')
    		</foreach>       
    </select>
    
    <select id="findByCategoryId" resultType="jp.co.internous.framepj.model.domain.MstProduct">
		SELECT *
		FROM mst_product
		WHERE category_id = #{categoryId}
    </select>
</mapper>